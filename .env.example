# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. Shared by apps/api and packages/db.
# ─────────────────────────────────────────────────────────────

# Railway Postgres — include the schema search path
DATABASE_URL="postgresql://user:pass@host:5432/railway?schema=food_ordering"

# Server
PORT=8000
NODE_ENV=development

# Better Auth — BETTER_AUTH_URL is the WEB origin (browser reaches /api/auth/*
# through the Next rewrites proxy, so OAuth callbacks + cookies stay same-origin).
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
WEB_ORIGIN="http://localhost:3000"

# Google OAuth (optional — cut-line if unavailable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Paymob (Egypt) sandbox
# Real Paymob is used only when: mode=sandbox + all keys present + webhook is
# reachable (NODE_ENV=production, or PAYMOB_FORCE_LIVE=true for a local tunnel).
# Local dev otherwise uses the mock gateway so orders never stall on the webhook.
PAYMOB_MODE="mock"             # "sandbox" | "mock"
PAYMOB_FORCE_LIVE="false"      # set "true" to hit real sandbox locally (e.g. via ngrok)
PAYMOB_BASE_URL="https://accept.paymob.com"  # override if your account is on another domain
PAYMOB_SECRET_KEY=""           # Dashboard → Settings → Account Info → Secret Key
PAYMOB_PUBLIC_KEY=""           # Dashboard → Settings → Account Info → Public Key
PAYMOB_INTEGRATION_ID=""       # Dashboard → Developers → Payment Integrations → (numeric ID)
PAYMOB_HMAC_SECRET=""          # Dashboard → Settings → Account Info → HMAC

# ── Web app (apps/web) ──
NEXT_PUBLIC_APP_NAME="Koshary House"
# Cloudinary unsigned upload for admin product images (create an *unsigned*
# upload preset in the Cloudinary dashboard). Optional — falls back to URL input.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
# Origin of the Express API the Next rewrites proxy points to
API_PROXY_TARGET="http://localhost:8000"
