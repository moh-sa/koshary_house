{
  "name": "food-ordering",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @food/db push",
    "db:seed": "pnpm --filter @food/api seed",
    "db:studio": "pnpm --filter @food/db studio",
    "auth:generate": "pnpm --filter @food/api auth:generate"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@tailwindcss/oxide", "sharp"]
  }
}
